<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" 
  xsi:type="MailApp">
  
  <Id>f523f5af-9cde-40e5-80d0-4f6c6105647d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>SmartBlue</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Blue AI"/>
  <Description DefaultValue="AI Document Analysis"/>
  
  <!-- FIX: Icons MUST be .png (using your Google Drive logo) -->
  <IconUrl DefaultValue="https://drive.google.com/uc?export=view&amp;id=1yJHr2KTerdWdd7T9IabCYBCJzlzaFbLS"/>
  <HighResolutionIconUrl DefaultValue="https://drive.google.com/uc?export=view&amp;id=1yJHr2KTerdWdd7T9IabCYBCJzlzaFbLS"/>
  
  <SupportUrl DefaultValue="https://ws.demo.smartblue.ai"/>
  
  <Hosts>
    <Host Name="Mail"/>
  </Hosts>
  
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://lavsingh108.github.io/Outlook-Add-in/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  
  <Permissions>ReadItem</Permissions>
  
  <Rule xsi:type="RuleCollection" Mode="And">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="Mailbox">
        <DesktopFormFactor>
          <FunctionFile resid="residFunctionFileUrl"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="residGroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="residPaneButtonLabel"/>
                  <Supertip>
                    <Title resid="residPaneButtonLabel"/>
                    <Description resid="residPaneButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="residIcon16"/>
                    <bt:Image size="32" resid="residIcon32"/>
                    <bt:Image size="80" resid="residIcon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="residTaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="residIcon16" DefaultValue="https://drive.google.com/uc?export=view&amp;id=1yJHr2KTerdWdd7T9IabCYBCJzlzaFbLS"/>
        <bt:Image id="residIcon32" DefaultValue="https://drive.google.com/uc?export=view&amp;id=1yJHr2KTerdWdd7T9IabCYBCJzlzaFbLS"/>
        <bt:Image id="residIcon80" DefaultValue="https://drive.google.com/uc?export=view&amp;id=1yJHr2KTerdWdd7T9IabCYBCJzlzaFbLS"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="residFunctionFileUrl" DefaultValue="https://lavsingh108.github.io/Outlook-Add-in/taskpane.html"/>
        <bt:Url id="residTaskpaneUrl" DefaultValue="https://lavsingh108.github.io/Outlook-Add-in/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="residGroupLabel" DefaultValue="SmartBlue"/>
        <bt:String id="residPaneButtonLabel" DefaultValue="Analyse with Blue AI"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="residPaneButtonDesc" DefaultValue="Open the Blue AI analysis pane for this document."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>