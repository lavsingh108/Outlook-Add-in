<!-- 1. Update Requirement Set to 1.8 -->
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
  <Requirements>
    <bt:Sets DefaultMinVersion="1.8">
      <bt:Set Name="Mailbox"/>
    </bt:Sets>
  </Requirements>
  
  <Hosts>
    <Host xsi:type="MailHost">
      <DesktopFormFactor>
        <!-- 2. Point FunctionFile to command.html, NOT taskpane.html -->
        <FunctionFile resid="Commands.Url"/>
        <!-- ... rest of your code ... -->
      </DesktopFormFactor>
    </Host>
  </Hosts>

  <Resources>
    <bt:Urls>
      <bt:Url id="Taskpane.Url" DefaultValue="https://lavsingh108.github.io/Outlook-Add-in/taskpane.html"/>
      <!-- 3. Add the Commands.Url resource -->
      <bt:Url id="Commands.Url" DefaultValue="https://lavsingh108.github.io/Outlook-Add-in/command.html"/>
    </bt:Urls>
    <!-- ... rest of your resources ... -->
  </Resources>
</VersionOverrides>